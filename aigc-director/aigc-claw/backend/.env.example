# Server Configuration
HOST=127.0.0.1
PORT=8000
DEBUG=True

################################################# API KEYS & URLS #################################################

# OpenAI / Compatible API Configuration
# 可用模型: gpt-4o(LLM), gpt-4o-mini(LLM), gpt-4.1(LLM), gpt-4.1-mini(LLM), gpt-5(LLM), o3(LLM), o4-mini(LLM) 等
OPENAI_API_KEY="your_openai_api_key"
OPENAI_BASE_URL="http://35.164.11.19:3887/v1"

# 官方 OpenAI API Key（用于 gpt-image-1.5 等需要直连官方的模型，走 LOCAL_PROXY 代理）
# 可用模型: gpt-image-1.5(文生图)
OPENAI_OFFICIAL_API_KEY="your_openai_official_key"
OPENAI_OFFICIAL_BASE_URL="https://api.openai.com/v1"

# Gemini API Configuration
# 可用模型: gemini-2.5-flash(LLM), gemini-2.0-flash(LLM), gemini-2.5-flash-image(VLM), gemini-2.0-flash-image(VLM)
GEMINI_API_KEY="your_gemini_api_key"
GOOGLE_GEMINI_BASE_URL="http://35.164.11.19:3887"

# DeepSeek API Configuration
# 可用模型: deepseek-chat(LLM), deepseek-reasoner(LLM)
DEEPSEEK_API_KEY="your_deepseek_api_key"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# Dashscope(Aliyun) API Configuration
# 可用模型: qwen3.5-plus(LLM), qwen3.5-max(LLM), qwen-plus(LLM), qwen-vl-plus(VLM), wan2.6-t2i(文生图), wan2.6-i2v-flash(视频), wan2.6-i2v(视频) 等
DASHSCOPE_API_KEY="your_dashscope_api_key"
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/api/v1"

# Jimeng Image API Configuration (字节跳动火山引擎)
# 可用模型: jimeng_t2i_v40(文生图/图生图), jimeng_ti2v_v30_pro(视频)
VOLC_ACCESS_KEY="your_volc_access_key"
VOLC_SECRET_KEY="your_volc_secret_key"
VOLC_BASE_URL="https://visual.volcengineapi.com"

# Kling AI (快手可灵) API Configuration
# 可用模型: kling-v3(视频), kling-v2-6(视频), kling-v2-5-turbo(视频)
KLING_ACCESS_KEY="your_kling_access_key"
KLING_SECRET_KEY="your_kling_secret_key"
KLING_BASE_URL="https://api-beijing.klingai.com"

# ByteDance ARK (Seedream) API Configuration
# 可用模型: doubao-seedream-5-0-260128(文生图/图生图), doubao-seedream-4-5-251128, doubao-seedream-4-0-250828
ARK_API_KEY="your_ark_api_key"
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"

# -----------------------------------------------------------------------------------------------------------------

# http proxy settings
PROXY=""
LOCAL_PROXY="http://127.0.0.1:7897"
HTTP_PROXY=""
HTTPS_PROXY=""

# LLM Configuration
LLM_MODEL="qwen3.5-plus"

# Image Generation
IMAGE_IT2I_MODEL="doubao-seedream-5-0-260128"
IMAGE_T2I_MODEL="doubao-seedream-5-0-260128"

# Video Generation
VIDEO_MODEL="wan2.6-i2v-flash"
VIDEO_RATIO="16:9"

# Evaluation Configuration
EVAL_MODEL="qwen3.5-plus"

# Control whether to print the prompt/input sent to models (LLM, Image, Video)
PRINT_MODEL_INPUT = True

# Admin password for session management (delete history records)
ADMIN_PASSWORD="your_admin_password"
